{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dailydigest",
  "compatibility_date": "2026-07-19",
  "main": "worker/index.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  }

,"d1_databases": [{
 "binding": "DB",
 "database_name": "daily-digest-comments",
 "database_id": "94547be8-acf5-47bd-a471-18a155835924",
 "migrations_dir": "migrations"
 }]
}
